<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SenseiGram" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:statusBarColor">@color/surface_light</item>
        <item name="android:navigationBarColor">@color/surface_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
    
    <style name="Theme.SenseiGram.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    
    <style name="Theme.SenseiGram.Amoled" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    
    <style name="Widget.SenseiGram.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/corner_md</item>
    </style>
    
    <style name="Widget.SenseiGram.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">@dimen/corner_md</item>
    </style>
    
    <style name="Widget.SenseiGram.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_lg</item>
        <item name="cardElevation">@dimen/card_elevation</item>
    </style>
    
    <style name="Widget.SenseiGram.Input" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_md</item>
    </style>
    
    <style name="TextAppearance.SenseiGram.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_2xl</item>
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.SenseiGram.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/text_secondary_light</item>
    </style>
</resources>
