<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Light Theme -->
    <style name="Theme.SenseiGram" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="android:statusBarColor">@color/background_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bottom_nav_light</item>
        <item name="android:windowBackground">@color/background_light</item>
    </style>

    <!-- Dark Theme -->
    <style name="Theme.SenseiGram.Dark" parent="Theme.MaterialComponents.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bottom_nav_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- AMOLED Theme -->
    <style name="Theme.SenseiGram.Amoled" parent="Theme.MaterialComponents.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background_amoled</item>
        <item name="colorSurface">@color/surface_amoled</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="android:statusBarColor">@color/background_amoled</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowBackground">@color/background_amoled</item>
    </style>

    <!-- Input Style -->
    <style name="Widget.SenseiGram.Input" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_lg</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_lg</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_lg</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_lg</item>
    </style>

    <!-- Primary Button -->
    <style name="Widget.SenseiGram.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">@dimen/corner_lg</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
    </style>

    <!-- Secondary Button -->
    <style name="Widget.SenseiGram.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_lg</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <!-- Glass Card -->
    <style name="Widget.SenseiGram.GlassCard" parent="">
        <item name="android:background">@drawable/bg_glass_panel</item>
        <item name="android:padding">@dimen/spacing_lg</item>
    </style>

</resources>
