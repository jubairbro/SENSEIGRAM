<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SenseiGram" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Input Style -->
    <style name="Widget.SenseiGram.Input" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_md</item>
    </style>

    <!-- Primary Button -->
    <style name="Widget.SenseiGram.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">@dimen/corner_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Secondary Button -->
    <style name="Widget.SenseiGram.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>

</resources>
