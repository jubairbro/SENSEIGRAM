<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Inline Button"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/primary"/>

    <EditText
        android:id="@+id/btnText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Button Text"
        android:inputType="text"
        android:maxLines="1"/>

    <EditText
        android:id="@+id/btnUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="URL (optional)"
        android:inputType="textUri"
        android:maxLines="1"/>

    <EditText
        android:id="@+id/btnCallback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Callback Data (optional)"
        android:inputType="text"
        android:maxLines="1"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Button Style"
        android:textStyle="bold"/>

    <RadioGroup
        android:id="@+id/rgStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <RadioButton
            android:id="@+id/styleDefault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Default"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/stylePrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Primary"
            android:buttonTint="@color/btn_primary"/>

        <RadioButton
            android:id="@+id/styleSuccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Success"
            android:buttonTint="@color/btn_success"/>

        <RadioButton
            android:id="@+id/styleDanger"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Danger"
            android:buttonTint="@color/btn_danger"/>

    </RadioGroup>

</LinearLayout>
