<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Mode Switcher -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:orientation="horizontal"
            android:padding="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/newPostTab"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/new_post_mode"
                android:textAllCaps="true"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:cornerRadius="@dimen/corner_md" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editPostTab"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/edit_post_mode"
                android:textAllCaps="true"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:cornerRadius="@dimen/corner_md" />
        </LinearLayout>

        <!-- New Post: Channel Selector (Spinner-like) -->
        <LinearLayout
            android:id="@+id/newPostSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="vertical">

            <Spinner
                android:id="@+id/channelSpinner"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="@dimen/spacing_lg" />

            <EditText
                android:id="@+id/manualChatIdInput"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_input"
                android:hint="@string/chat_id"
                android:inputType="text"
                android:maxLines="1"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:textSize="@dimen/text_md"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Edit Post: Link Input -->
        <LinearLayout
            android:id="@+id/editPostSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal"
            android:visibility="gone">

            <EditText
                android:id="@+id/postLinkInput"
                android:layout_width="0dp"
                android:layout_height="@dimen/input_height"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="@string/paste_link"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:textSize="@dimen/text_md" />

            <ImageButton
                android:id="@+id/parseLinkBtn"
                android:layout_width="@dimen/input_height"
                android:layout_height="@dimen/input_height"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_connected"
                android:contentDescription="@string/edit"
                android:src="@drawable/ic_link"
                android:padding="@dimen/spacing_md"
                app:tint="@color/primary" />
        </LinearLayout>

        <!-- Edit Options (text/buttons checkboxes) -->
        <LinearLayout
            android:id="@+id/editOptionsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_warning"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/what_to_update"
                android:textAllCaps="true"
                android:textColor="@color/warning_text"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/editTextCheck"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="@string/text_caption"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_md" />

                <CheckBox
                    android:id="@+id/editButtonsCheck"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/buttons_label"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_md" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/edit_hint"
                android:textColor="@color/warning_text"
                android:textSize="@dimen/text_xs"
                android:alpha="0.7" />
        </LinearLayout>

        <!-- Media Attach Buttons -->
        <LinearLayout
            android:id="@+id/mediaAttachSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/attach"
                android:textAllCaps="true"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:paddingEnd="@dimen/spacing_sm" />

            <ImageButton
                android:id="@+id/attachPhoto"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_input"
                android:src="@drawable/ic_image"
                android:padding="@dimen/spacing_sm"
                android:contentDescription="@string/type_photo"
                app:tint="?android:textColorSecondary" />

            <ImageButton
                android:id="@+id/attachVideo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_input"
                android:src="@drawable/ic_video"
                android:padding="@dimen/spacing_sm"
                android:contentDescription="@string/type_video"
                app:tint="?android:textColorSecondary" />

            <ImageButton
                android:id="@+id/attachDocument"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_input"
                android:src="@drawable/ic_file"
                android:padding="@dimen/spacing_sm"
                android:contentDescription="@string/type_document"
                app:tint="?android:textColorSecondary" />

            <!-- Media type label -->
            <TextView
                android:id="@+id/mediaTypeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_xs"
                android:visibility="gone"
                tools:text="Sending Photo"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Media Upload/URL section -->
        <LinearLayout
            android:id="@+id/mediaInputSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_dashed_border"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg"
            android:visibility="gone">

            <!-- Upload/Link toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/uploadToggle"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="@string/upload_label"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/linkToggle"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="@string/link_label"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- File picker row -->
            <LinearLayout
                android:id="@+id/filePickerRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:src="@drawable/ic_paperclip"
                    android:contentDescription="@null"
                    app:tint="@color/primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/fileNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_file"
                        android:textSize="@dimen/text_md"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/max_file_size"
                        android:textColor="?android:textColorTertiary"
                        android:textSize="@dimen/text_xs" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pickFileBtn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_label"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- URL input row -->
            <EditText
                android:id="@+id/mediaUrlInput"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:background="@null"
                android:hint="@string/media_url_placeholder"
                android:inputType="textUri"
                android:maxLines="1"
                android:textSize="@dimen/text_md"
                android:visibility="gone" />

            <!-- Spoiler checkbox -->
            <CheckBox
                android:id="@+id/spoilerCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/spoiler"
                android:textAllCaps="true"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Editor Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="2dp">

            <TextView
                android:id="@+id/editorLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/message_text"
                android:textAllCaps="true"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/saveDraftBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_save"
                android:drawablePadding="@dimen/spacing_xs"
                android:text="@string/save_draft_btn"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:padding="@dimen/spacing_xs" />
        </LinearLayout>

        <!-- Message Input -->
        <EditText
            android:id="@+id/messageInput"
            android:layout_width="match_parent"
            android:layout_height="@dimen/editor_height"
            android:background="@drawable/bg_card"
            android:gravity="top|start"
            android:hint="@string/enter_message"
            android:inputType="textMultiLine"
            android:padding="@dimen/spacing_lg"
            android:textSize="@dimen/text_md"
            android:scrollbars="vertical" />

        <!-- Formatting Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_toolbar"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_sm">

            <ImageButton
                android:id="@+id/btnBold"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bold"
                android:src="@drawable/ic_bold"
                app:tint="?android:textColorSecondary"
                android:padding="@dimen/spacing_sm" />

            <ImageButton
                android:id="@+id/btnItalic"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Italic"
                android:src="@drawable/ic_italic"
                app:tint="?android:textColorSecondary"
                android:padding="@dimen/spacing_sm" />

            <ImageButton
                android:id="@+id/btnCode"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Code"
                android:src="@drawable/ic_code"
                app:tint="?android:textColorSecondary"
                android:padding="@dimen/spacing_sm" />

            <ImageButton
                android:id="@+id/btnLink"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Link"
                android:src="@drawable/ic_link"
                app:tint="?android:textColorSecondary"
                android:padding="@dimen/spacing_sm" />

            <ImageButton
                android:id="@+id/btnSpoiler"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Spoiler"
                android:src="@drawable/ic_eye_off"
                app:tint="?android:textColorSecondary"
                android:padding="@dimen/spacing_sm" />
        </LinearLayout>

        <!-- Send Options -->
        <LinearLayout
            android:id="@+id/sendOptionsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/silentCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/silent"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/protectCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:text="@string/protect"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/hidePreviewCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:text="@string/hide_preview"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Inline Buttons Builder -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openInlineButtonsBtn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_md"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="Add Inline Buttons"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="@dimen/corner_lg"
            app:icon="@drawable/ic_link"
            app:iconTint="?attr/colorPrimary"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/spacing_sm" />

        <!-- Send Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendBtn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_lg"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/send_now"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/corner_lg"
            app:icon="@drawable/ic_send"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/spacing_sm" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/sendProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_sm"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_xxl" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
