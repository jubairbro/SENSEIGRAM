<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Build Inline Buttons"
        android:textAllCaps="true"
        android:textColor="?attr/colorOnSurface"
        android:textSize="@dimen/text_md"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="@dimen/spacing_md" />

    <!-- Button rows preview -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/buttonsPreviewRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        android:nestedScrollingEnabled="false" />

    <!-- Add button inputs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/btnLabelInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="2"
            android:background="@drawable/bg_input"
            android:hint="Label"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="@dimen/spacing_md"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface"
            android:textSize="@dimen/text_md" />

        <EditText
            android:id="@+id/btnUrlInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="3"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_input"
            android:hint="URL or Callback Data"
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingHorizontal="@dimen/spacing_md"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface"
            android:textSize="@dimen/text_md" />
    </LinearLayout>

    <!-- Style selection -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Color/Style:"
            android:textColor="?attr/colorOnSurface"
            android:layout_gravity="center_vertical"
            android:paddingEnd="@dimen/spacing_sm" />
        <Spinner
            android:id="@+id/btnStyleSpinner"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addToRowBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Add to Row"
            android:textAllCaps="false"
            android:textSize="@dimen/text_xs"
            android:textStyle="bold"
            app:cornerRadius="@dimen/corner_md" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/newRowBtn"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="New Row"
            android:textAllCaps="false"
            android:textSize="@dimen/text_xs"
            android:textStyle="bold"
            app:backgroundTint="?attr/colorPrimary"
            android:textColor="?attr/colorOnPrimary"
            app:cornerRadius="@dimen/corner_md" />
    </LinearLayout>
    
    <com.google.android.material.button.MaterialButton
        android:id="@+id/closeDialogBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="Done"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="@dimen/corner_md" />

</LinearLayout>