<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="@dimen/corner_xl"
    app:cardElevation="@dimen/elevation_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/channel_card_padding">

        <!-- Avatar circle -->
        <TextView
            android:id="@+id/channelInitial"
            android:layout_width="@dimen/icon_xxl"
            android:layout_height="@dimen/icon_xxl"
            android:background="@drawable/bg_connected"
            android:gravity="center"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="M" />

        <TextView
            android:id="@+id/channelTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            tools:text="My Channel" />

        <TextView
            android:id="@+id/channelId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:textColor="?android:textColorTertiary"
            android:textSize="@dimen/text_xs"
            tools:text="-1001234567" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
