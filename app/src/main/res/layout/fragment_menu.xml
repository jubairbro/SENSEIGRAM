<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:id="@+id/menuTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/menu_title"
                android:textSize="@dimen/text_hero"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/system_config"
                android:textAllCaps="true"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_xs"
                android:alpha="0.6"
                android:letterSpacing="0.12"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Appearance Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appearance"
                android:textAllCaps="true"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/themeLight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">
                    <ImageView
                        android:id="@+id/themeLightIcon"
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_sun"
                        android:contentDescription="@null"
                        app:tint="?android:textColorTertiary" />
                    <TextView
                        android:id="@+id/themeLightLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/theme_light"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/themeDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">
                    <ImageView
                        android:id="@+id/themeDarkIcon"
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_moon"
                        android:contentDescription="@null"
                        app:tint="?android:textColorTertiary" />
                    <TextView
                        android:id="@+id/themeDarkLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/theme_dark"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/themeAmoled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">
                    <ImageView
                        android:id="@+id/themeAmoledIcon"
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_smartphone"
                        android:contentDescription="@null"
                        app:tint="?android:textColorTertiary" />
                    <TextView
                        android:id="@+id/themeAmoledLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/theme_amoled"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/themeSystem"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">
                    <ImageView
                        android:id="@+id/themeSystemIcon"
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_monitor"
                        android:contentDescription="@null"
                        app:tint="?android:textColorTertiary" />
                    <TextView
                        android:id="@+id/themeSystemLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/theme_system"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Bot Connection Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_bot"
                android:drawablePadding="@dimen/spacing_sm"
                android:text="@string/connection"
                android:textAllCaps="true"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:drawableTint="?android:textColorTertiary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/tokenInput"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:drawableStart="@drawable/ic_settings"
                    android:drawablePadding="@dimen/spacing_sm"
                    android:hint="@string/bot_token_hint"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:textSize="@dimen/text_md"
                    android:fontFamily="monospace"
                    app:drawableTint="?android:textColorTertiary" />

                <ImageButton
                    android:id="@+id/toggleTokenVisibility"
                    android:layout_width="@dimen/input_height"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:background="@drawable/bg_input"
                    android:src="@drawable/ic_eye_off"
                    android:padding="@dimen/spacing_md"
                    android:contentDescription="Toggle visibility"
                    app:tint="?android:textColorSecondary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/validateBtn"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/check_connection"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="@dimen/text_md"
                app:backgroundTint="?android:textColorPrimary"
                android:textColor="@color/white"
                app:cornerRadius="@dimen/corner_md" />

            <!-- Connected status -->
            <LinearLayout
                android:id="@+id/connectedStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_connected"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg"
                android:visibility="gone">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/primary" />

                <TextView
                    android:id="@+id/connectedText"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_md"
                    android:textStyle="bold"
                    tools:text="Connected: @my_bot" />
                    
                <ImageButton
                    android:id="@+id/editBotProfileBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_edit"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/primary"
                    android:contentDescription="Edit Bot Profile" />
            </LinearLayout>
        </LinearLayout>

        <!-- Lookup Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="@dimen/spacing_sm"
                android:text="@string/lookup_info"
                android:textAllCaps="true"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:drawableTint="?android:textColorTertiary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/lookupInput"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="@string/lookup_hint"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingHorizontal="@dimen/spacing_lg"
                    android:textSize="@dimen/text_md" />

                <ImageButton
                    android:id="@+id/lookupBtn"
                    android:layout_width="@dimen/input_height"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:src="@drawable/ic_search"
                    android:padding="@dimen/spacing_md"
                    android:contentDescription="Search"
                    app:tint="@color/white"
                    app:backgroundTint="@color/primary" />
            </LinearLayout>

            <!-- Lookup result -->
            <LinearLayout
                android:id="@+id/lookupResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_input"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_xxl"
                        android:layout_height="@dimen/icon_xxl"
                        android:background="@drawable/bg_connected"
                        android:padding="@dimen/spacing_sm"
                        android:src="@drawable/ic_user"
                        android:contentDescription="@null"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/lookupTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="@dimen/text_lg"
                            android:singleLine="true"
                            tools:text="My Channel" />

                        <TextView
                            android:id="@+id/lookupType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAllCaps="true"
                            android:textColor="?android:textColorTertiary"
                            android:textSize="@dimen/text_xs"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            tools:text="channel" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/lookupId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:fontFamily="monospace"
                    android:textSize="@dimen/text_sm"
                    android:textIsSelectable="true"
                    tools:text="ID: -1001234567890" />

                <TextView
                    android:id="@+id/lookupUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/blue_accent"
                    android:fontFamily="monospace"
                    android:textSize="@dimen/text_sm"
                    android:textIsSelectable="true"
                    android:visibility="gone"
                    tools:text="@mychannel" />
            </LinearLayout>
        </LinearLayout>

        <!-- Targets Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_user"
                android:drawablePadding="@dimen/spacing_sm"
                android:text="@string/targets"
                android:textAllCaps="true"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:drawableTint="?android:textColorTertiary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_lg">

                <EditText
                    android:id="@+id/newChannelInput"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="@string/channel_or_id"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingHorizontal="@dimen/spacing_lg"
                    android:textSize="@dimen/text_md" />

                <ImageButton
                    android:id="@+id/addChannelBtn"
                    android:layout_width="@dimen/input_height"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:src="@drawable/ic_add"
                    android:padding="@dimen/spacing_md"
                    android:contentDescription="Add"
                    app:tint="@color/white"
                    app:backgroundTint="@color/primary" />
            </LinearLayout>
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fetchUsersBtn"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="Fetch recent users"
                android:textAllCaps="false"
                app:icon="@drawable/ic_bot"
                app:iconGravity="textStart" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/noChannelsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:padding="@dimen/spacing_xl"
                android:text="@string/no_channels"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_sm"
                android:visibility="gone" />

            <!-- Channels list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/channelsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- Settings Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:text="@string/settings_label"
            android:textAllCaps="true"
            android:textColor="?android:textColorTertiary"
            android:textSize="@dimen/text_xs"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Color Accents -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_glass_panel"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg">

            <ImageButton
                android:id="@+id/accentEmerald"
                android:layout_width="@dimen/color_dot_size"
                android:layout_height="@dimen/color_dot_size"
                android:background="@drawable/circle_color_selector"
                android:contentDescription="Emerald"
                app:tint="@color/emerald" />

            <ImageButton
                android:id="@+id/accentBlue"
                android:layout_width="@dimen/color_dot_size"
                android:layout_height="@dimen/color_dot_size"
                android:layout_marginStart="@dimen/spacing_lg"
                android:background="@drawable/circle_color_selector"
                android:contentDescription="Blue"
                app:tint="@color/blue_accent" />

            <ImageButton
                android:id="@+id/accentViolet"
                android:layout_width="@dimen/color_dot_size"
                android:layout_height="@dimen/color_dot_size"
                android:layout_marginStart="@dimen/spacing_lg"
                android:background="@drawable/circle_color_selector"
                android:contentDescription="Violet"
                app:tint="@color/violet" />

            <ImageButton
                android:id="@+id/accentRose"
                android:layout_width="@dimen/color_dot_size"
                android:layout_height="@dimen/color_dot_size"
                android:layout_marginStart="@dimen/spacing_lg"
                android:background="@drawable/circle_color_selector"
                android:contentDescription="Rose"
                app:tint="@color/rose" />

            <ImageButton
                android:id="@+id/accentAmber"
                android:layout_width="@dimen/color_dot_size"
                android:layout_height="@dimen/color_dot_size"
                android:layout_marginStart="@dimen/spacing_lg"
                android:background="@drawable/circle_color_selector"
                android:contentDescription="Amber"
                app:tint="@color/amber" />
        </LinearLayout>

        <!-- Settings Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_label"
                android:textAllCaps="true"
                android:textColor="?android:textColorTertiary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Smooth Scroll -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/smooth_scroll"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/smooth_scroll_desc"
                        android:textColor="?android:textColorTertiary"
                        android:textSize="@dimen/text_xs" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/smoothScrollSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Haptic Feedback -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/haptic_feedback"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/haptic_feedback_desc"
                        android:textColor="?android:textColorTertiary"
                        android:textSize="@dimen/text_xs" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/hapticSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- Social Links -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/telegramLink"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_glass_panel"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_send"
                    android:contentDescription="@null"
                    app:tint="@color/telegram_blue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/telegram_label"
                    android:textColor="@color/telegram_blue"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/youtubeLink"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_md"
                android:background="@drawable/bg_glass_panel"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_video"
                    android:contentDescription="@null"
                    app:tint="@color/youtube_red" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/youtube_label"
                    android:textColor="@color/youtube_red"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Join Support -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/joinSupportBtn"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/join_support"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/telegram_blue"
            app:cornerRadius="@dimen/corner_lg"
            app:icon="@drawable/ic_telegram"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/spacing_sm" />

        <!-- Disconnect -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/disconnectBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/disconnect"
            android:textAllCaps="false"
            android:textColor="@color/error_text"
            app:cornerRadius="@dimen/corner_lg"
            app:strokeColor="@color/error_text" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_xxl" />

    </LinearLayout>
