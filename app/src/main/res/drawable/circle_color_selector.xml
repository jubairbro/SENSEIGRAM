<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="?android:attr/colorControlActivated"/>
            <solid android:color="#1A10B981"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="@color/text_secondary_light"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</selector>
